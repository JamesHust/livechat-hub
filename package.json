{
  "name": "livechat-hub",
  "version": "0.1.0",
  "private": true,
  "description": "LiveChat Hub — reusable, AI-provider-agnostic live chat frontend platform",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "size": "size-limit",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "changeset publish",
    "docs:api": "pnpm --filter @livechat-hub/sdk docs:api",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@livechat-hub/eslint-config": "workspace:*",
    "@livechat-hub/tsconfig": "workspace:*",
    "@size-limit/file": "^11.1.6",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "size-limit": "^11.1.6",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}

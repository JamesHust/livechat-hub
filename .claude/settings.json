{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm dlx:*)",
      "Bash(turbo:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)"
    ],
    "deny": ["Read(./**/.env)", "Read(./**/.env.*)", "Read(./**/*.pem)"],
    "ask": ["Bash(git push:*)", "Bash(pnpm publish:*)", "Bash(npm publish:*)"]
  },
  "env": {
    "TURBO_TELEMETRY_DISABLED": "1",
    "DO_NOT_TRACK": "1"
  }
}
